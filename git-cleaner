#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" >/dev/null 2>&1 && pwd)"
CFG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/git-cleaner"
KEYS_FILE="$CFG_DIR/keys.txt"
EXCEPTIONS_FILE="$CFG_DIR/exceptions.txt"
BLACKLIST_FILE="$CFG_DIR/blacklist.txt"
CONFIG_FILE="$CFG_DIR/config.txt"
PYTHON_SCRIPT="$SCRIPT_DIR/githubapi.py"
REQ_FILE="$SCRIPT_DIR/requirements.txt"

LANG_CODE="en"

ensure_cfg(){
  mkdir -p "$CFG_DIR"
  touch "$KEYS_FILE" "$EXCEPTIONS_FILE" "$BLACKLIST_FILE"
  [ -f "$KEYS_FILE" ] && chmod 600 "$KEYS_FILE" || true
}

read_lang(){
  if [ -n "${GIT_CLEANER_LANG:-}" ]; then
    LANG_CODE="$GIT_CLEANER_LANG"
  elif [ -f "$CONFIG_FILE" ]; then
    local from_file
    from_file=$(awk -F= '/^[[:space:]]*lang[[:space:]]*=/ {gsub(/[[:space:]]/,"",$2); print $2; exit}' "$CONFIG_FILE" 2>/dev/null || true)
    [ -n "$from_file" ] && LANG_CODE="$from_file"
  fi
  case "$LANG_CODE" in
    en|ko) ;;
    *) LANG_CODE="en" ;;
  esac
}

write_lang(){
  local new="$1"
  mkdir -p "$CFG_DIR"
  local tmp
  tmp=$(mktemp)
  if [ -f "$CONFIG_FILE" ]; then
    grep -v '^[[:space:]]*lang[[:space:]]*=' "$CONFIG_FILE" > "$tmp" || true
  fi
  echo "lang=$new" >> "$tmp"
  mv "$tmp" "$CONFIG_FILE"
}

t(){
  local key="$1"; shift
  case "${LANG_CODE}_${key}" in
    en_added)             printf "Added %s to %s\n" "$1" "$2" ;;
    ko_added)             printf "'%s' 을(를) %s 에 추가했습니다\n" "$1" "$2" ;;
    en_already_in)        printf "%s already in %s\n" "$1" "$2" ;;
    ko_already_in)        printf "'%s' 은(는) 이미 %s 에 있습니다\n" "$1" "$2" ;;
    en_no_usernames)      echo "No usernames provided." ;;
    ko_no_usernames)      echo "사용자명이 입력되지 않았습니다." ;;
    en_exceptions_header) echo " EXCEPTIONS LIST" ;;
    ko_exceptions_header) echo " 예외 목록 (EXCEPTIONS)" ;;
    en_blacklist_header)  echo " BLACKLIST LIST" ;;
    ko_blacklist_header)  echo " 블랙리스트 (BLACKLIST)" ;;
    en_empty)             echo "  (empty)" ;;
    ko_empty)             echo "  (비어 있음)" ;;
    en_checking_deps)     echo "Checking Python dependencies..." ;;
    ko_checking_deps)     echo "Python 의존성을 확인 중..." ;;
    en_installing_deps)   echo "Installing dependencies from requirements.txt..." ;;
    ko_installing_deps)   echo "requirements.txt 에서 의존성을 설치 중..." ;;
    en_req_not_found)     printf "Warning: requirements.txt not found at %s\n" "$1" ;;
    ko_req_not_found)     printf "경고: %s 에서 requirements.txt 를 찾을 수 없습니다\n" "$1" ;;
    en_pip_not_found)     echo "pip3 not found. Please install Python3 and pip first." ;;
    ko_pip_not_found)     echo "pip3 를 찾을 수 없습니다. 먼저 Python3 와 pip 를 설치해주세요." ;;
    en_deps_ok)           echo "All dependencies already satisfied." ;;
    ko_deps_ok)           echo "모든 의존성이 이미 설치되어 있습니다." ;;
    en_python_not_found)  echo "Python3 not found. Please install it first." ;;
    ko_python_not_found)  echo "Python3 를 찾을 수 없습니다. 먼저 설치해주세요." ;;
    en_prompt_username)   printf "Enter your GitHub username: " ;;
    ko_prompt_username)   printf "GitHub 사용자명을 입력하세요: " ;;
    en_pat_instructions)  echo "Create a Personal access token (classic) with permission: user:follow (follow/unfollow)" ;;
    ko_pat_instructions)  echo "Personal Access Token (classic) 을 생성하세요. 필요한 권한: user:follow (팔로우/언팔로우)" ;;
    en_prompt_token)      printf "Enter your personal access token: " ;;
    ko_prompt_token)      printf "Personal Access Token 을 입력하세요: " ;;
    en_keys_saved)        printf "Saved keys to %s\n" "$1" ;;
    ko_keys_saved)        printf "인증 정보를 %s 에 저장했습니다\n" "$1" ;;
    en_no_python_script)  printf "Can't find githubapi.py at %s\n" "$1" ;;
    ko_no_python_script)  printf "githubapi.py 를 %s 에서 찾을 수 없습니다\n" "$1" ;;
    en_brew_note)         echo "If you installed via brew, the wrapper generated by the formula will handle this." ;;
    ko_brew_note)         echo "brew 로 설치했다면 formula 가 생성한 wrapper 가 이를 처리합니다." ;;
    en_unknown_cmd)       printf "Unknown command: %s\n" "$1" ;;
    ko_unknown_cmd)       printf "알 수 없는 명령어입니다: %s\n" "$1" ;;
    en_help_hint)         echo "Try 'git-cleaner -h' for help." ;;
    ko_help_hint)         echo "도움말은 'git-cleaner -h' 를 참고하세요." ;;
    en_lang_current)      printf "Current language: %s\n" "$1" ;;
    ko_lang_current)      printf "현재 언어: %s\n" "$1" ;;
    en_lang_set)          printf "Language set to: %s\n" "$1" ;;
    ko_lang_set)          printf "언어가 다음으로 설정되었습니다: %s\n" "$1" ;;
    en_lang_invalid)      echo "Invalid language. Use 'en' or 'ko'." ;;
    ko_lang_invalid)      echo "잘못된 언어 값입니다. 'en' 또는 'ko' 를 사용하세요." ;;
    *) printf "[missing:%s:%s]\n" "$LANG_CODE" "$key" ;;
  esac
}

add_users_to_file(){
  local file="$1"; shift
  for u in "$@"; do
    if [ -z "$u" ]; then continue; fi
    if ! grep -qxF "$u" "$file"; then
      echo "$u" >> "$file"
      t added "$u" "$(basename "$file")"
    else
      t already_in "$u" "$(basename "$file")"
    fi
  done
}

show_help(){
  if [ "$LANG_CODE" = "ko" ]; then
    cat <<'EOF'
git-cleaner - GitHub 팔로워/팔로잉 자동 관리 도구

사용법:
  git-cleaner run
    맞팔 동기화: 맞팔하지 않는 사람 언팔로우, 새 팔로워 맞팔
    (~/.config/git-cleaner/* 파일 참조)

  git-cleaner discover [--min-overlap N] [--max-follows N] [--dry-run]
    내가 팔로우하는 사람들이 공통으로 팔로우하는 유저를 찾아 자동 팔로우
    기본값: --min-overlap 2, --max-follows 20
    처음에는 반드시 --dry-run 으로 후보를 먼저 확인하세요.

  git-cleaner harvest stargazers --repo owner/name [--limit N] [--sleep S] [--dry-run]
  git-cleaner harvest followers --user USERNAME [--limit N] [--sleep S] [--dry-run]
    팔로워 성장에 효과적인 소스에서 대상을 직접 수집해 팔로우합니다.
    - stargazers: 특정 repo 를 최근에 스타한 활성 유저
    - followers:  특정 유저의 최근 팔로워 (맞팔률 높은 계정 많음)
    기본값: --limit 20, --sleep 1.0 (초), 하루 50명 이하 권장
    이력은 ~/.config/git-cleaner/harvested.txt 에 자동 기록되어 재시도 방지됩니다.

  git-cleaner -e username1 username2 ...
    예외 목록(exceptions)에 사용자 추가 — 항상 팔로우 상태 유지

  git-cleaner -b username1 username2 ...
    블랙리스트(blacklist)에 사용자 추가 — 절대 팔로우하지 않음

  git-cleaner view
    현재 exceptions / blacklist 목록 출력

  git-cleaner lang [en|ko]
    UI 언어 표시 또는 설정 (config.txt 에 저장)
    환경변수 GIT_CLEANER_LANG 이 설정되어 있으면 그쪽이 우선 적용됩니다.

  git-cleaner setup
    대화형 초기 설정:
    - requirements.txt 기반 Python 의존성 확인/설치
    - GitHub 사용자명 및 Personal Access Token 을 ~/.config/git-cleaner/keys.txt 에 저장
    - UI 언어 선택

  git-cleaner -h
    이 도움말 출력

참고: PATH 에 git-cleaner 가 있으면 `git cleaner ...` 형태로도 호출됩니다.
EOF
  else
    cat <<'EOF'
git-cleaner - manage GitHub follower/following cleanup

Usage:
  git-cleaner run
    Run the Python cleanup (reads ~/.config/git-cleaner/* files).

  git-cleaner discover [--min-overlap N] [--max-follows N] [--dry-run]
    Discover and follow users who are followed by people you already follow.
    Defaults: --min-overlap 2, --max-follows 20.
    Use --dry-run first to preview candidates without following.

  git-cleaner harvest stargazers --repo owner/name [--limit N] [--sleep S] [--dry-run]
  git-cleaner harvest followers --user USERNAME [--limit N] [--sleep S] [--dry-run]
    Harvest followers from high-value pools (much more effective than discover
    for growing your follower count):
    - stargazers: recent stargazers of a given repo (active, topical users)
    - followers:  recent followers of a given user (often f4f-friendly)
    Defaults: --limit 20, --sleep 1.0s. Stay under ~50/day to avoid throttling.
    History is recorded to ~/.config/git-cleaner/harvested.txt to prevent
    re-attempts across runs.

  git-cleaner -e username1 username2 ...
    Add username(s) to exceptions (you will always follow them).

  git-cleaner -b username1 username2 ...
    Add username(s) to blacklist (you will not follow them).

  git-cleaner view
    Show a prettified list of exceptions and blacklist usernames.

  git-cleaner lang [en|ko]
    Show or set the UI language (stored in config.txt).
    The GIT_CLEANER_LANG environment variable, if set, overrides this.

  git-cleaner setup
    Interactive setup:
    - checks Python dependencies from requirements.txt
    - installs them if missing
    - saves username & personal access token to ~/.config/git-cleaner/keys.txt
    - picks a UI language

  git-cleaner -h
    Show this help message.

Tip: when git-cleaner is on your PATH, git discovers it as `git cleaner ...`.
EOF
  fi
}

read_lang

case "${1:-}" in
  (run)
    if [ ! -f "$PYTHON_SCRIPT" ]; then
      t no_python_script "$PYTHON_SCRIPT"
      t brew_note
      exit 1
    fi
    shift || true
    GIT_CLEANER_LANG="$LANG_CODE" python3 "$PYTHON_SCRIPT" run "$@"
    ;;
  (discover)
    if [ ! -f "$PYTHON_SCRIPT" ]; then
      t no_python_script "$PYTHON_SCRIPT"
      exit 1
    fi
    shift || true
    GIT_CLEANER_LANG="$LANG_CODE" python3 "$PYTHON_SCRIPT" discover "$@"
    ;;
  (harvest)
    if [ ! -f "$PYTHON_SCRIPT" ]; then
      t no_python_script "$PYTHON_SCRIPT"
      exit 1
    fi
    shift || true
    GIT_CLEANER_LANG="$LANG_CODE" python3 "$PYTHON_SCRIPT" harvest "$@"
    ;;
  (view)
    ensure_cfg
    echo ""
    echo "============================="
    t exceptions_header
    echo "============================="
    if [ -s "$EXCEPTIONS_FILE" ]; then
      n=1
      while IFS= read -r line; do
        [ -z "$line" ] && continue
        printf "  %2d. %s\n" "$n" "$line"
        n=$((n+1))
      done < "$EXCEPTIONS_FILE"
    else
      t empty
    fi
    echo ""
    echo "============================="
    t blacklist_header
    echo "============================="
    if [ -s "$BLACKLIST_FILE" ]; then
      n=1
      while IFS= read -r line; do
        [ -z "$line" ] && continue
        printf "  %2d. %s\n" "$n" "$line"
        n=$((n+1))
      done < "$BLACKLIST_FILE"
    else
      t empty
    fi
    echo ""
    ;;
  (-e)
    shift || true
    if [ $# -eq 0 ]; then t no_usernames; exit 1; fi
    ensure_cfg
    add_users_to_file "$EXCEPTIONS_FILE" "$@"
    ;;
  (-b)
    shift || true
    if [ $# -eq 0 ]; then t no_usernames; exit 1; fi
    ensure_cfg
    add_users_to_file "$BLACKLIST_FILE" "$@"
    ;;
  (lang)
    shift || true
    if [ $# -eq 0 ]; then
      t lang_current "$LANG_CODE"
    else
      new_lang="$1"
      case "$new_lang" in
        en|ko)
          ensure_cfg
          write_lang "$new_lang"
          LANG_CODE="$new_lang"
          t lang_set "$new_lang"
          ;;
        *)
          t lang_invalid
          exit 1
          ;;
      esac
    fi
    ;;
  (setup)
    ensure_cfg

    printf "Select language / 언어 선택 [en/ko] (default: en): "
    read -r setup_lang
    setup_lang=$(echo "${setup_lang:-en}" | tr '[:upper:]' '[:lower:]')
    case "$setup_lang" in
      en|ko) ;;
      *) setup_lang="en" ;;
    esac
    write_lang "$setup_lang"
    LANG_CODE="$setup_lang"
    t lang_set "$setup_lang"

    t checking_deps
    if command -v python3 >/dev/null 2>&1; then
      if ! python3 -c "import requests" >/dev/null 2>&1; then
        t installing_deps
        if command -v pip3 >/dev/null 2>&1; then
          if [ -f "$REQ_FILE" ]; then
            pip3 install --user -r "$REQ_FILE"
          else
            t req_not_found "$REQ_FILE"
          fi
        else
          t pip_not_found
          exit 1
        fi
      else
        t deps_ok
      fi
    else
      t python_not_found
      exit 1
    fi

    t prompt_username
    read -r gh_user
    echo
    t pat_instructions
    t prompt_token
    read -s -r gh_token
    echo
    printf "username=%s\n token=%s\n" "$gh_user" "$gh_token" > "$KEYS_FILE"
    chmod 600 "$KEYS_FILE"
    t keys_saved "$KEYS_FILE"
    ;;
  (-h|--help|"")
    show_help
    ;;
  (*)
    t unknown_cmd "$1"
    t help_hint
    exit 1
    ;;
esac
